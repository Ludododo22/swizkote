# ─── Base de données ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:ludovic@localhost:5432/bank_db

PORT=3001
SESSION_SECRET=une_chaine_secrete_tres_longue_pour_les_sessions_swizkobebank
NODE_ENV=development

# ─── URL de l'application (utilisée dans les emails) ─────────────────────────
APP_URL=https://app.swizkote.ch

# ─── Configuration SMTP (envoi d'emails automatiques) ────────────────────────
# Si non configuré, les emails sont uniquement loggés dans la console (mode dev)
#
# Exemple avec Gmail :
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=votre-adresse@gmail.com
# SMTP_PASS=votre-mot-de-passe-application
# SMTP_FROM=noreply@swizkote.ch
#
# Exemple avec un serveur SMTP propre (recommandé pour la production) :
# SMTP_HOST=mail.swizkote.ch
# SMTP_PORT=465
# SMTP_USER=noreply@swizkote.ch
# SMTP_PASS=mot_de_passe_smtp_securise
# SMTP_FROM=SwizKote Bank <noreply@swizkote.ch>
#
# Exemple avec Brevo (ex-Sendinblue) ou Mailgun :
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=votre-login-brevo
# SMTP_PASS=votre-cle-api-brevo

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@swizkote.ch
